#!/bin/bash

#ddev-generated

config_path="$DDEV_APPROOT/.ddev/.invrt/config.yaml"

if [[ -f "$config_path" ]] && grep -q "#ddev-generated" "$config_path"; then
    echo "InVRT configuration already exists at $config_path and is marked as ddev-generated. Skipping configuration to avoid overwriting custom settings."
    exit 0
fi

echo "Configuring InVRT for $DDEV_HOSTNAME"
echo "\
#ddev-generated
# This file was generated by ddev invrt configure. To update it, run 'ddev invrt configure' again.
# If you want to edit it, remove the #ddev-generated line.

title: $(ddev drush config:get system.site name --format=list)

environments:

  local:
    name: DDEV Local
    url: http://$DDEV_HOSTNAME

$(ddev invrt-environment | sed 's/^/  /')

profiles:

  anonymous:
    name: Anonymous user

$(ddev invrt-profile | sed 's/^/  /')

devices:

  mobile:
    name: Mobile
    viewport_width: 375
    viewport_height: 667
    
  desktop:
    name: Desktop
    viewport_width: 1280
    viewport_height: 800

$(ddev invrt-device | sed 's/^/  /')
" | tee "$DDEV_APPROOT/.ddev/.invrt/config.yaml"
